generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String           @id @default(cuid())
  email              String           @unique
  username           String           @unique
  password           String
  name               String?
  avatar             String?
  avatarSeed         String?
  avatarStyle        String?
  bio                String?
  favoriteTeamId     String?
  favoritePlayer     String?
  goldenBoot1stPlayerId  String?
  goldenBoot1stPlayer    Player?  @relation("GoldenBoot1st", fields: [goldenBoot1stPlayerId], references: [id], onDelete: SetNull)
  goldenBoot2ndPlayerId  String?
  goldenBoot2ndPlayer    Player?  @relation("GoldenBoot2nd", fields: [goldenBoot2ndPlayerId], references: [id], onDelete: SetNull)
  goldenBoot3rdPlayerId  String?
  goldenBoot3rdPlayer    Player?  @relation("GoldenBoot3rd", fields: [goldenBoot3rdPlayerId], references: [id], onDelete: SetNull)
  role               UserRole         @default(USER)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  accounts           Account[]
  invitationsCreated InvitationCode[]
  predictions        Prediction[]
  sessions           Session[]
  favoriteTeam       Team?            @relation(fields: [favoriteTeamId], references: [id])
}

model InvitationCode {
  id          String    @id @default(cuid())
  code        String    @unique
  createdById String
  usedById    String?   @unique
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  createdBy   User      @relation(fields: [createdById], references: [id])
}

model Tournament {
  id         String   @id @default(cuid())
  name       String
  externalId Int?     @unique
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  matches    Match[]
}

model Team {
  id               String   @id @default(cuid())
  externalId       Int      @unique
  name             String
  shortName        String
  tla              String
  crestUrl         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  awayMatches      Match[]  @relation("AwayTeam")
  homeMatches      Match[]  @relation("HomeTeam")
  qualifiedMatches Match[]  @relation("QualifierTeam")
  fans             User[]
    players      Player[]
  predictionQualifiers Prediction[] @relation("PredictionQualifier")
}

model Match {
  id              String       @id @default(cuid())
  externalId      Int          @unique
  tournamentId    String
  stage           MatchStage
  group           String?
  homeTeamId      String?
  awayTeamId      String?
  kickoffAt       DateTime
  status          MatchStatus  @default(SCHEDULED)
  homeScore       Int?
  awayScore       Int?
  homeExtraTime   Int?
  awayExtraTime   Int?
  homePenalties   Int?
  awayPenalties   Int?
  qualifierTeamId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  awayTeam        Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam        Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  qualifierTeam   Team?        @relation("QualifierTeam", fields: [qualifierTeamId], references: [id])
  tournament      Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  predictions     Prediction[]
}

model Prediction {
  id              String   @id @default(cuid())
  userId          String
  matchId         String
  homeScore       Int
  awayScore       Int
  qualifierTeamId String?
  pointsEarned    Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  qualifierTeam   Team?    @relation("PredictionQualifier", fields: [qualifierTeamId], references: [id])

  @@unique([userId, matchId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum UserRole {
  USER
  ADMIN
}

enum MatchStage {
  GROUP
  ROUND_32
  ROUND_16
  QUARTER
  SEMI
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

model Player {
  id          String    @id @default(cuid())
  externalId  Int       @unique             // ID API football-data.org
  name        String
  position    String?                       // "Defence" / "Midfield" / "Offence" (pas de Goalkeeper)
  dateOfBirth DateTime?
  nationality String?

  // Équipe d'appartenance pendant le tournoi
  teamId      String
  team        Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Reverse relations pour les 3 pronos Soulier d'Or
  goldenBoot1stPredictions  User[]  @relation("GoldenBoot1st")
  goldenBoot2ndPredictions  User[]  @relation("GoldenBoot2nd")
  goldenBoot3rdPredictions  User[]  @relation("GoldenBoot3rd")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([teamId])
}
